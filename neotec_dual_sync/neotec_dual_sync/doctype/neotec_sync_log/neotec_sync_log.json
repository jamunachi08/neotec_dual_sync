{
  "doctype": "DocType",
  "name": "Neotec Sync Log",
  "module": "Neotec Dual Sync",
  "custom": 0,
  "is_submittable": 0,
  "is_tree": 0,
  "istable": 0,
  "issingle": 0,
  "engine": "InnoDB",
  "track_changes": 1,
  "autoname": "hash",
  "sort_field": "modified",
  "sort_order": "DESC",
  "fields": [
    {
      "fieldname": "reference_doctype",
      "label": "Reference DocType",
      "fieldtype": "Data",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reference_name",
      "label": "Reference Name",
      "fieldtype": "Data",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "rule",
      "label": "Rule",
      "fieldtype": "Data",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "trigger_source",
      "label": "Trigger Source",
      "fieldtype": "Data",
      "read_only": 1
    },
    {
      "fieldname": "status",
      "label": "Status",
      "fieldtype": "Select",
      "options": "Queued\nProcessing\nSuccess\nFailed\nRetry\nSkipped",
      "default": "Queued",
      "in_list_view": 1
    },
    {
      "fieldname": "retry_count",
      "label": "Retry Count",
      "fieldtype": "Int",
      "default": "0",
      "read_only": 1
    },
    {
      "fieldname": "target_document_name",
      "label": "Target Document Name",
      "fieldtype": "Data",
      "read_only": 1
    },
    {
      "fieldname": "payload_json",
      "label": "Payload JSON",
      "fieldtype": "Long Text"
    },
    {
      "fieldname": "response_json",
      "label": "Response JSON",
      "fieldtype": "Long Text"
    },
    {
      "fieldname": "error_message",
      "label": "Error Message",
      "fieldtype": "Long Text"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "share": 1,
      "print": 1,
      "email": 1,
      "export": 1
    },
    {
      "role": "Neotec Dual Sync Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "share": 1,
      "print": 1,
      "email": 1,
      "export": 1
    }
  ]
}