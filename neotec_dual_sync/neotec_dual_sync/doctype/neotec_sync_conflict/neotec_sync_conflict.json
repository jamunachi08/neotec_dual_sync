{
  "doctype": "DocType",
  "name": "Neotec Sync Conflict",
  "module": "Neotec Dual Sync",
  "custom": 0,
  "istable": 0,
  "issingle": 0,
  "engine": "InnoDB",
  "track_changes": 1,
  "is_submittable": 0,
  "sort_field": "creation",
  "sort_order": "DESC",
  "fields": [
    {
      "fieldname": "reference_doctype",
      "label": "Reference DocType",
      "fieldtype": "Link",
      "options": "DocType",
      "in_list_view": 1,
      "reqd": 1
    },
    {
      "fieldname": "reference_name",
      "label": "Reference Name",
      "fieldtype": "Data",
      "in_list_view": 1,
      "reqd": 1
    },
    {
      "fieldname": "source_instance_id",
      "label": "Source Instance ID",
      "fieldtype": "Data",
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "label": "Status",
      "fieldtype": "Select",
      "options": "Open\nResolved\nIgnored",
      "default": "Open",
      "in_list_view": 1
    },
    {
      "fieldname": "reason",
      "label": "Reason",
      "fieldtype": "Small Text",
      "reqd": 1
    },
    {
      "fieldname": "resolved_by",
      "label": "Resolved By",
      "fieldtype": "Link",
      "options": "User"
    },
    {
      "fieldname": "resolved_on",
      "label": "Resolved On",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "section_payloads",
      "label": "Payload Comparison",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "payload_before",
      "label": "Existing Document (Before)",
      "fieldtype": "Code",
      "options": "JSON"
    },
    {
      "fieldname": "payload_after",
      "label": "Incoming Document (After)",
      "fieldtype": "Code",
      "options": "JSON"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "share": 1, "print": 1, "email": 1, "export": 1
    },
    {
      "role": "Neotec Dual Sync Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "share": 1, "print": 1, "email": 1, "export": 1
    },
    {
      "role": "Neotec Dual Sync User",
      "read": 1, "export": 1
    }
  ]
