{
  "doctype": "DocType",
  "name": "Neotec Sync Batch",
  "module": "Neotec Dual Sync",
  "custom": 0,
  "is_submittable": 0,
  "is_tree": 0,
  "istable": 0,
  "issingle": 0,
  "engine": "InnoDB",
  "track_changes": 1,
  "autoname": "format:SYNC-BATCH-.#####",
  "sort_field": "modified",
  "sort_order": "DESC",
  "fields": [
    {
      "fieldname": "batch_name",
      "label": "Batch Name",
      "fieldtype": "Data"
    },
    {
      "fieldname": "source_doctype",
      "label": "Source DocType",
      "fieldtype": "Link",
      "options": "DocType",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "rule",
      "label": "Rule",
      "fieldtype": "Data"
    },
    {
      "fieldname": "filters_json",
      "label": "Filters JSON",
      "fieldtype": "Code",
      "options": "JSON"
    },
    {
      "fieldname": "batch_limit",
      "label": "Batch Limit",
      "fieldtype": "Int",
      "default": "100"
    },
    {
      "fieldname": "status",
      "label": "Status",
      "fieldtype": "Select",
      "options": "Draft\nRunning\nCompleted\nFailed",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "processed_count",
      "label": "Processed Count",
      "fieldtype": "Int",
      "read_only": 1,
      "default": "0"
    },
    {
      "fieldname": "last_run_on",
      "label": "Last Run On",
      "fieldtype": "Datetime",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "share": 1,
      "print": 1,
      "email": 1,
      "export": 1
    },
    {
      "role": "Neotec Dual Sync Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "share": 1,
      "print": 1,
      "email": 1,
      "export": 1
    }
  ]
}